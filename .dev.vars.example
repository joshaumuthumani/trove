# Local secrets for `wrangler dev` / `opennextjs-cloudflare preview`.
# Copy to `.dev.vars` (gitignored) and fill in. In production set these as
# Cloudflare secrets instead (dashboard or `wrangler secret put`).

# TMDB v3 API key — https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# RAWG API key — https://rawg.io/apidocs
RAWG_API_KEY=

# Trakt app client_id (optional) — https://trakt.tv/oauth/applications
# Powers the on-demand "Augment seasons from Trakt" button on TV detail pages.
TRAKT_API_KEY=

# Twitch app credentials (optional) — https://dev.twitch.tv/console/apps
# Power IGDB game search + cover art. Client-credentials flow (no redirect used).
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
